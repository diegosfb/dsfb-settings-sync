{
  "name": "dsfb-settings-sync",
  "displayName": "DSFB Settings Sync",
  "description": "Sync settings, keybindings, and extensions for Antigravity via GitHub Gist",
  "version": "0.2.3",
  "publisher": "diegosfb",
  "engines": {
    "vscode": "^1.90.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/diegosfb/dsfb-settings-sync"
  },
  "homepage": "https://github.com/diegosfb/dsfb-settings-sync#readme",
  "bugs": {
    "url": "https://github.com/diegosfb/dsfb-settings-sync/issues"
  },
  "gitlab": "https://gitlab.com/diegosfb/dsfb-settings-sync",
  "keywords": [
    "antigravity",
    "settings-sync",
    "backup",
    "gist",
    "personalization",
    "sync"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dsfbSettingsSync.login",
        "title": "DSFB Settings Sync: Login to GitHub"
      },
      {
        "command": "dsfbSettingsSync.logout",
        "title": "DSFB Settings Sync: Logout from GitHub"
      },
      {
        "command": "dsfbSettingsSync.syncNow",
        "title": "DSFB Settings Sync: Sync Now (Upload & Download)"
      },
      {
        "command": "dsfbSettingsSync.uploadNow",
        "title": "DSFB Settings Sync: Upload Settings to Gist"
      },
      {
        "command": "dsfbSettingsSync.downloadNow",
        "title": "DSFB Settings Sync: Download Settings from Gist"
      },
      {
        "command": "dsfbSettingsSync.showHistory",
        "title": "DSFB Settings Sync: Show Gist History"
      },
      {
        "command": "dsfbSettingsSync.setGistId",
        "title": "DSFB Settings Sync: Set Gist ID"
      },
      {
        "command": "dsfbSettingsSync.switchProfile",
        "title": "DSFB Settings Sync: Switch Profile"
      },
      {
        "command": "dsfbSettingsSync.configureIgnoredExtensions",
        "title": "DSFB Settings Sync: Manage Ignored Extensions"
      },
      {
        "command": "dsfbSettingsSync.configureIgnoredSettings",
        "title": "DSFB Settings Sync: Manage Ignored Settings"
      },
      {
        "command": "dsfbSettingsSync.checkExtensionHealth",
        "title": "익스텐션 마켓플레이스 헬스체크",
        "category": "DSFB Sync"
      },
      {
        "command": "dsfbSettingsSync.runSettingsE2ETest",
        "title": "설정 E2E 테스트 실행",
        "category": "DSFB Sync"
      },
      {
        "command": "dsfbSettingsSync.setCustomMarketplaceUrl",
        "title": "Custom Marketplace URL 설정",
        "category": "DSFB Sync"
      },
      {
        "command": "dsfbSettingsSync.togglePublicGist",
        "title": "Public Gist 토글 (공개/비공개)",
        "category": "DSFB Sync"
      },
      {
        "command": "dsfbSettingsSync.showLocalVsRemoteDiff",
        "title": "로컬 vs 원격 설정 Diff 보기",
        "category": "DSFB Sync"
      },
      {
        "command": "dsfbSettingsSync.addMarketplace",
        "title": "마켓플레이스 추가",
        "category": "DSFB Sync"
      },
      {
        "command": "dsfbSettingsSync.removeMarketplace",
        "title": "마켓플레이스 제거",
        "category": "DSFB Sync"
      },
      {
        "command": "dsfbSettingsSync.reorderMarketplace",
        "title": "마켓플레이스 스캔 순서 변경",
        "category": "DSFB Sync"
      },
      {
        "command": "dsfbSettingsSync.toggleCustomMarketplaceAutoUpdate",
        "title": "커스텀 마켓 자동 업데이트 토글",
        "category": "DSFB Sync"
      },
      {
        "command": "dsfbSettingsSync.checkCustomMarketplaceUpdates",
        "title": "커스텀 마켓 업데이트 확인",
        "category": "DSFB Sync"
      },
      {
        "command": "dsfbSettingsSync.registerPrivateExtension",
        "title": "사설 익스텐션 등록",
        "category": "DSFB Sync"
      },
      {
        "command": "dsfbSettingsSync.removePrivateExtension",
        "title": "사설 익스텐션 제거",
        "category": "DSFB Sync"
      },
      {
        "command": "dsfbSettingsSync.shareSettings",
        "title": "설정 공유 (Share Your Settings)",
        "category": "DSFB Sync"
      },
      {
        "command": "dsfbSettingsSync.openSettings",
        "title": "설정 열기",
        "category": "DSFB Sync"
      },
      {
        "command": "dsfbSettingsSync.openRepository",
        "title": "GitHub 저장소 열기",
        "category": "DSFB Sync"
      },
      {
        "command": "dsfbSettingsSync.reportIssue",
        "title": "이슈/버그 신고",
        "category": "DSFB Sync"
      },
      {
        "command": "dsfbSettingsSync.showLog",
        "title": "로그 보기",
        "category": "DSFB Sync"
      },
      {
        "command": "dsfbSettingsSync.copyStatusBarItemIds",
        "title": "DSFB Settings Sync: Copy Status Bar Item IDs",
        "category": "DSFB Sync"
      },
      {
        "command": "dsfbSettingsSync.getStarted",
        "title": "Getting Started",
        "category": "DSFB Sync"
      }
    ],
    "keybindings": [
      {
        "command": "dsfbSettingsSync.syncNow",
        "key": "shift+alt+s",
        "mac": "shift+cmd+s"
      },
      {
        "command": "dsfbSettingsSync.uploadNow",
        "key": "shift+alt+u",
        "mac": "shift+cmd+u"
      },
      {
        "command": "dsfbSettingsSync.downloadNow",
        "key": "shift+alt+d",
        "mac": "shift+cmd+d"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dsfb-sync-explorer",
          "title": "DSFB Settings Sync",
          "icon": "$(sync)"
        }
      ]
    },
    "views": {
      "dsfb-sync-explorer": [
        {
          "id": "dsfbSettingsSync.treeView",
          "name": "Actions",
          "icon": "$(sync)"
        }
      ]
    },
    "configuration": {
      "title": "DSFB Settings Sync",
      "properties": {
        "dsfbSettingsSync.gistId": {
          "type": "string",
          "default": "",
          "description": "GitHub Gist ID for settings sync. Leave empty to auto-create on first upload."
        },
        "dsfbSettingsSync.autoSyncOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Automatically download and apply settings from Gist on startup. Requires dsfbSettingsSync.autoSync=true."
        },
        "dsfbSettingsSync.autoSync": {
          "type": "boolean",
          "default": false,
          "description": "Master toggle for automatic sync behavior. When false, startup sync and auto-upload file watchers are disabled (manual commands still work)."
        },
        "dsfbSettingsSync.autoUploadOnChange": {
          "type": "boolean",
          "default": true,
          "description": "Automatically upload settings to Gist when local files change. Requires dsfbSettingsSync.autoSync=true."
        },
        "dsfbSettingsSync.autoUploadDelay": {
          "type": "number",
          "default": 5000,
          "description": "Delay in milliseconds before auto-uploading after a change is detected."
        },
        "dsfbSettingsSync.syncPreview": {
          "type": "boolean",
          "default": true,
          "description": "Show a sync preview (diff summary) before applying downloaded changes."
        },
        "dsfbSettingsSync.confirmExtensionSync": {
          "type": "boolean",
          "default": true,
          "description": "Ask for confirmation before installing or uninstalling extensions during download."
        },
        "dsfbSettingsSync.gistTrust": {
          "type": "object",
          "default": {},
          "description": "Per-Gist trust setting. Untrusted gists block extension install/uninstall during download. Example: { \"<gistId>\": \"trusted\" }",
          "additionalProperties": {
            "type": "string",
            "enum": [
              "trusted",
              "untrusted"
            ]
          }
        },
        "dsfbSettingsSync.ignoredSettings": {
          "type": "array",
          "default": [
            "*token*",
            "*secret*",
            "*password*",
            "*apikey*",
            "*api_key*"
          ],
          "description": "Settings keys to ignore during sync (glob patterns supported). Example: [\"terminal.integrated.profiles.*\"]. Common secret-key examples are included by default.",
          "items": {
            "type": "string"
          }
        },
        "dsfbSettingsSync.removeExtensions": {
          "type": "boolean",
          "default": false,
          "description": "Automatically uninstall local extensions that are not in the remote list."
        },
        "dsfbSettingsSync.publicGist": {
          "type": "boolean",
          "default": false,
          "description": "Create new sync Gists as Public (visible to anyone). Defaults to Private for security."
        },
        "dsfbSettingsSync.syncSettings": {
          "type": "boolean",
          "default": true,
          "description": "Sync VS Code settings (settings.json)."
        },
        "dsfbSettingsSync.authoritativeDownload": {
          "type": "boolean",
          "default": false,
          "description": "원격 settings.json을 authoritative하게 적용할지 여부입니다. false면 기존 deep merge를 유지하고, true면 동기화 대상 키는 원격값으로 그대로 덮어써서 원격에서 삭제된 키도 로컬에서 제거합니다."
        },
        "dsfbSettingsSync.syncExtensions": {
          "type": "boolean",
          "default": true,
          "description": "Sync installed extensions list."
        },
        "dsfbSettingsSync.syncKeybindings": {
          "type": "boolean",
          "default": true,
          "description": "Sync keyboard shortcuts (keybindings.json)."
        },
        "dsfbSettingsSync.syncSnippets": {
          "type": "boolean",
          "default": true,
          "description": "Sync user snippets."
        },
        "dsfbSettingsSync.syncStatusBarState": {
          "type": "boolean",
          "default": false,
          "description": "Sync status bar UI state (hidden/reordered items) from storage.json when available."
        },
        "dsfbSettingsSync.statusBarItems": {
          "type": "array",
          "default": [],
          "description": "Optional list of status bar item IDs (from the status bar context menu) to include in status-bar.json for reference across machines.",
          "items": {
            "type": "string"
          }
        },
        "dsfbSettingsSync.syncAntigravityConfig": {
          "type": "boolean",
          "default": true,
          "description": "Sync Antigravity-only config files (antigravity.json, browserAllowlist.txt). If not explicitly set, runtime default follows platform: true on Antigravity, false on VS Code."
        },
        "dsfbSettingsSync.ignoredExtensions": {
          "type": "array",
          "default": [],
          "description": "List of extension IDs to ignore during sync. Example: [\"ms-vscode.cpptools\"]",
          "items": {
            "type": "string"
          }
        },
        "dsfbSettingsSync.profiles": {
          "type": "object",
          "default": {},
          "description": "Stored sync profiles by name. Each profile stores gistId, ignoredSettings, and ignoredExtensions."
        },
        "dsfbSettingsSync.currentProfile": {
          "type": "string",
          "default": "Default",
          "description": "The name of the currently active sync profile."
        },
        "dsfbSettingsSync.customMarketplaceUrl": {
          "type": "string",
          "default": "",
          "description": "Custom marketplace base URL (OpenVSX-compatible REST API). Used as fallback when extension status is unknown in the primary marketplace. Example: https://my-marketplace.example.com"
        },
        "dsfbSettingsSync.marketplaceRegistry": {
          "type": "object",
          "default": {},
          "description": "Custom marketplace registry. Maps domain key (e.g. 'open-vsx.org') to base URL. Example: { \"my-market.example.com\": \"https://my-market.example.com\" }",
          "additionalProperties": {
            "type": "string"
          }
        },
        "dsfbSettingsSync.marketplaceScanOrder": {
          "type": "array",
          "default": [],
          "description": "Domain keys defining the scan order for marketplace fallback. Earlier entries are checked first.",
          "items": {
            "type": "string"
          }
        },
        "dsfbSettingsSync.customMarketplaceAutoUpdate": {
          "type": "boolean",
          "default": false,
          "description": "Automatically install updates found in custom marketplaces without prompting."
        },
        "dsfbSettingsSync.customMarketplaceUpdateCheck": {
          "type": "string",
          "enum": [
            "startup",
            "disabled"
          ],
          "default": "disabled",
          "description": "When to check for updates from custom marketplaces. 'startup' checks on activation, 'disabled' disables automatic checks."
        },
        "dsfbSettingsSync.privateExtensions": {
          "type": "array",
          "default": [],
          "description": "List of private/unlisted extensions for sync guidance. Each entry has id, version, optional vsixUrl, localPath, and note.",
          "items": {
            "type": "object",
            "required": [
              "id",
              "version"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "Extension ID (publisher.name)"
              },
              "version": {
                "type": "string",
                "description": "Extension version"
              },
              "vsixUrl": {
                "type": "string",
                "description": "Direct VSIX download URL for automatic install"
              },
              "localPath": {
                "type": "string",
                "description": "Local .vsix file path for manual guidance"
              },
              "note": {
                "type": "string",
                "description": "Optional note for this extension"
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "build:vsix": "bash scripts/build-vsix.sh",
    "release:vsix": "bash scripts/create-release.sh",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "20.x",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.57.0",
    "glob": "^10.3.15",
    "mocha": "^10.4.0",
    "ovsx": "^0.9.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  }
}
